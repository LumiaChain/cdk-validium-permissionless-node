# Directory under config/ and data/ (testnet | mainnet)
NETWORK_ENV=mainnet

# Basename for dynamic chain config files (must match chain: in the YAML and ChainName in chainspec JSON)
# Testnet: dynamic-lumia-beam-testnet
# Mainnet (Prism / CDN snapshot): dynamic-prism
CHAIN_CONFIG_BASENAME=dynamic-prism

# L1 RPC URL - IMPORTANT: Use a premium provider for better reliability
# For testnet: Use Sepolia endpoint (e.g., https://eth-sepolia.g.alchemy.com/v2/YOUR-API-KEY)
# For mainnet: Use Ethereum mainnet endpoint (e.g., https://eth-mainnet.g.alchemy.com/v2/YOUR-API-KEY)
CDK_ERIGON_L1_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR-API-KEY

# L2 Sequencer RPC URL
# Testnet default: https://beam-rpc.lumia.org
# Mainnet default: https://mainnet-rpc.lumia.org
CDK_ERIGON_ZKEVM_L2_SEQUENCER_RPC_URL=https://mainnet-rpc.lumia.org

# L2 Datastreamer URL
# Testnet Datastreamer URL: rpc-ds.lumia-beam-testnet.gateway.fm:6902
# Mainnet Datastreamer URL: rpc-ds.prism.gateway.fm:6903
CDK_ERIGON_L2_DATASTREAMER_URL=rpc-ds.prism.gateway.fm:6903

# CDK Erigon Docker Image
CDK_ERIGON_IMAGE=ghcr.io/0xpolygon/cdk-erigon:v2.65.0-RC2
